generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     Role     @default(USER)
  basket   Basket?
  ratings  Rating[]
}

model Basket {
  id     String       @id @default(uuid())
  userId String       @unique
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  BasketItem[]
}

model BasketItem {
  id        String  @id @default(uuid())
  basketId  String
  quantity  Int     @default(1)
  variantId String
  basket    Basket  @relation(fields: [basketId], references: [id], onDelete: Cascade)
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([basketId, variantId])
}

model Product {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  categoryId  String?
  category    Category?     @relation(fields: [categoryId], references: [id])
  productInfo ProductInfo[]
  ratings     Rating[]
  variants    Variant[]
}

model Variant {
  id          String       @id @default(uuid())
  sizeId      String?
  colorId     String?
  productId   String
  isDefault   Boolean      @default(false)
  price       Float
  stock       Int          @default(0)
  basketItems BasketItem[]
  images      Image[]
  color       Color?       @relation(fields: [colorId], references: [id])
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  size        Size?        @relation(fields: [sizeId], references: [id])
}

model Rating {
  id        String  @id @default(uuid())
  productId String
  userId    String
  rating    Float   @default(0.0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
}

model ProductInfo {
  id          String  @id @default(uuid())
  productId   String
  description String
  title       String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model Size {
  id       String    @id @default(uuid())
  name     String    @unique
  variants Variant[]
}

model Color {
  id       String    @id @default(uuid())
  name     String    @unique
  variants Variant[]
}

model Image {
  id        String  @id @default(uuid())
  url       String  @unique
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  USER
}
